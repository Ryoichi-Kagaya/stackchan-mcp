# Copy to nvs_config.env (gitignored) and fill in real values, then run gen_nvs.py.
# Values can also be provided via the process environment instead of this file.
BOARD_UUID=your-board-uuid
WIFI_SSID=your-wifi-ssid
WIFI_PASS=your-wifi-password
DISPLAY_THEME=light
WS_URL=ws://192.168.1.100:8765
WS_TOKEN=your-websocket-token
